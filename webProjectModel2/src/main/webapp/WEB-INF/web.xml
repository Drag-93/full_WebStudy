<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>webProjectModel2</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
  </welcome-file-list>
  
  <!-- DBCP 설정 -->
  <resource-ref>
  	<description>connectDBCP</description>
  	<res-ref-name>jdbc/mysqlDB</res-ref-name>
  	<res-type>javax.sql.DataSource</res-type>
  	<res-auth>Container</res-auth>
  </resource-ref>
  
  
  
  <!-- exceptiom, 에러페이지 -->
  <error-page>	<!-- 요청 페이지가 없을때 -->
  	<error-code>404</error-code>
  	<location>/error/error404.jsp</location>
  </error-page>
  <error-page>	<!-- 문법, 코드가 틀렸을때 -->
  	<error-code>500</error-code>
  	<location>/error/error500.jsp</location>
  </error-page>
  <error-page>	
  	<exception-type>java.lang.NullPionterException</exception-type>
  	<location>/error/errorNull.jsp</location>
  </error-page>
  <error-page>	<!-- 이메이르 아이디 검색 등의 인자가 없을때 -->
  	<exception-type>java.lang.IllegalArgumentException</exception-type>
  	<location>/error/errorIllegalArgument.jsp</location>
  </error-page>
  <error-page>	<!-- 리스트 조회, 회원가입, 회원수정 -->
  	<exception-type>java.lang.IllegalStateException</exception-type>
  	<location>/error/errorIllegalState.jsp</location>
  </error-page>
  
  
  <!-- servlet-mapping : 정적 파일(css,이미지)을 기본 서블릿이 처리하도록 설정 -->
  <servlet-mapping>
  	<servlet-name>default</servlet-name>
  	<url-pattern>*.css</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>default</servlet-name>
  	<url-pattern>*.jpg</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>default</servlet-name>
  	<url-pattern>*.png</url-pattern>
  </servlet-mapping>
  
  
  
  
  
  
  
</web-app>